# Supabase — get these from your Supabase project dashboard (Settings → API).
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

# Google Maps API key — required for react-native-maps (iOS and Android).
# Get a key at https://console.cloud.google.com/ with Maps SDK for iOS and Maps SDK for Android enabled.
GOOGLE_MAPS_API_KEY=""

# Google Places API key — required for address autocomplete in the publish wizard (step 2).
# Enable "Places API (New)" in your Google Cloud project.
# Without this key the address field still works as a free-text input.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=""
